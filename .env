# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.

# Ports
HTTP_PORT=8080
HTTPS_PORT=8443
HTTP3_PORT=8443

# api service variables
POSTGRES_PASSWORD=!ChangeMe!
APP_SECRET=
CADDY_MERCURE_JWT_SECRET=!ChangeMe!
JWT_PASSPHRASE=
TRUSTED_HEADERS=x-forwarded-for,x-forwarded-proto
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080/core-api
MAILER_DSN=smtp://localhost:1025

# frontend service variables
# Should be cryptographically secure and at least 32 characters long
# Auth.js CLI provides `npx auth secret` command that can be used for generating the secret
AUTH_SECRET=!ChangeMe!
AUTH_URL=http://localhost:8080
NEXT_PUBLIC_MERCURE_URL=http://localhost:8080/.well-known/mercure
NEXT_PUBLIC_API_URL=http://localhost:8080/core-api
NEXT_PUBLIC_API_ROUTE_PREFIX=/core-api

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
