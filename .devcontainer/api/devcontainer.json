{
  "name": "ProjectCollab - API Service",
  "dockerComposeFile": [
    "../../compose.yaml",
    "../../compose.override.yaml"
  ],
  "service": "api",
  "workspaceFolder": "/workspace/api",
  "runServices": [
    "api",
    "database",
    "redis",
    "mailer"
  ],
  "remoteUser": "symfony",
  "overrideCommand": false,
  "forwardPorts": [80, 443, 5432, 9003, 1025, 44949],
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "xdebug.php-debug",
        "felixfbecker.php-pack",
        "emeraldwalk.RunOnSave"
      ],
      "settings": {
        "php.suggest.basic": false
      }
    },
    "jetbrains": {
      "settings": {
        "com.intellij:app:HttpConfigurable.use_proxy_pac": true
      }
    }
  }
}

