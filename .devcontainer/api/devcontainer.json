{
  "name": "Attach to API Service",
  "dockerComposeFile": [
    "../../compose.yaml",
    "../../compose.override.yaml"
  ],
  "service": "api",
  "workspaceFolder": "/workspace/api",
  "runServices": [
    "api",
    "database",
    "redis",
    "mailer"
  ],
  "remoteUser": "symfony",
  "customizations": {
    "jetbrains": {
      "settings": {
        "com.intellij:app:HttpConfigurable.use_proxy_pac": true
      }
    }
  }
}
