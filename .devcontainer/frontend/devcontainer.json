{
  "name": "ProjectCollab - Frontend Service",
  "dockerComposeFile": [
    "../../compose.yaml",
    "../../compose.override.yaml"
  ],
  "service": "frontend",
  "workspaceFolder": "/workspace/frontend",
  "runServices": [
    "frontend",
    "api",
    "database",
    "redis",
    "mailer"
  ],
  "remoteUser": "next",
  "forwardPorts": [3000, 80, 443],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}

